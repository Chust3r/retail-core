# Database configuration

# PostgreSQL main user (used for authentication)
POSTGRES_USER=postgres

# PostgreSQL user password
# ⚠️ For development only (do not use in production)
POSTGRES_PASSWORD=postgres

# Database name created on container initialization
# Uses "retailcore" (no hyphens) for compatibility
POSTGRES_DB=retailcore

# Container timezone
# Recommended to keep UTC for consistency across systems
TZ=UTC


# pgAdmin configuration

# Email used to log in to pgAdmin (http://localhost:8080)
PGADMIN_DEFAULT_EMAIL=admin@retailcore.local

# Password for pgAdmin access
# ⚠️ For development only (do not use in production)
PGADMIN_DEFAULT_PASSWORD=admin